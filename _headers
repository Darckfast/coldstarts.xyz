/*
  Cache-Control: public, no-cache
  X-Frame-Options: DENY
  Permissions-Policy: fullscreen=(self), autoplay=(self)
  Content-Security-Policy: default-src 'self'; font-src 'self' https://fonts.gstatic.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' static.cloudflareinsights.com; img-src 'self' data:; connect-src 'self' cloudflareinsights.com;
  Cross-Origin-Opener-Policy: same-origin

/*.js
  Cache-Control: public, max-age=31536000

https://:project.pages.dev/*
  X-Robots-Tag: noindex

https://:version.:project.pages.dev/*
  X-Robots-Tag: noindex
